# ============================================================
# PORTFOLIO BACKEND — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (CORS) ───────────────────────────────────────────
# URL do seu portfólio Next.js
FRONTEND_URL=http://localhost:3000

# ── Banco de Dados (Supabase / PostgreSQL) ────────────────────
# Connection string com pgBouncer (para queries normais)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (para migrations do Prisma)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Autenticação JWT ──────────────────────────────────────────
# Gere uma string segura: openssl rand -base64 64
JWT_SECRET="substitua-por-uma-string-secreta-e-longa-aqui"

# ── Supabase Storage ──────────────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Service Role Key (NÃO use a anon key — precisa de permissão de storage)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Admin (usado pelo seed) ───────────────────────────────────
ADMIN_EMAIL=alex@portfolio.com
ADMIN_PASSWORD=SuaSenhaSegura@123
